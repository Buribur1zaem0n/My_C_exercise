void pritnf_diamond(int k)
{
	//k is the number of rows in upper half
	int i = 0;
	for (i = 0; i < k; i++)
	{
		int j = 0;
		for (j = 0; j < k - 1 - i; j++)
		{
			printf(" ");
		}
		for (j = 0; j < i * 2 + 1; j++)
		{
			printf("*");
		}
		printf("\n");
	}
	for (i = 0; i < k; i++)
	{
		int j = 0;
		for (j = 0; j <= i; j++)
		{
			printf(" ");
		}
		for (j = 0; j < 2 * (k - 1 - i) - 1; j++)
		{				
			printf("*");
		}
			printf("\n");
	}
}
