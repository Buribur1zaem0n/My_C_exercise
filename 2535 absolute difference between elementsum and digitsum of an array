//give a positive integer array nums,
//elementsum : is the sum of all elements in nums.
//digitsum : is the sum of all digit of each element in nums.
//return the absolute difference between elementsum and digitsum.

int differenceOfSum(int* nums, int numsSize) 
{
    int elementsum = 0;
    int digitsum = 0;
    for (int i = 0; i< numsSize;i++)
    {
    int num = nums[i];
    elementsum += num;
    while (num > 0)
    {
        digitsum += num % 10;
        num /= 10;
    }
    }
    return elementsum - digitsum;
}
